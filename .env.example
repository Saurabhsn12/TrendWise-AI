# TrendWise AI — Environment Configuration
# Copy this file to .env and fill in your values

# Flask Secret Key (change in production!)
SECRET_KEY=your-secret-key-here

# Database
DATABASE_PATH=trendwise.db

# AI Provider: 'local' (free, no key needed) or 'gemini' (needs API key)
AI_PROVIDER=local

# Google Gemini API Key (optional — get free key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Alpha Vantage API Key (optional)
ALPHA_VANTAGE_API_KEY=

# Flask Environment
FLASK_ENV=development
